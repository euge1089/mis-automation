# Example crontab entries for MLS Automation.
# Install with: crontab infra/cron.example
#
# IMPORTANT:
# - Update MLS_AUTOMATION_DIR for your machine.
# - These examples use hosted non-interactive scraping in headless mode.

SHELL=/bin/zsh
PATH=/usr/local/bin:/usr/bin:/bin

MLS_AUTOMATION_DIR=/Users/your-user/Documents/mls-automation

# Daily active refresh at 2:15am local time.
# This command now includes DB loading by default.
15 2 * * * cd "$MLS_AUTOMATION_DIR" && /bin/bash scripts/run_scheduled_pipeline.sh daily-active --with-scrape --headless

# Weekly sold/rented refresh + memorialization every Sunday at 3:30am.
30 3 * * 0 cd "$MLS_AUTOMATION_DIR" && /bin/bash scripts/run_scheduled_pipeline.sh weekly-sold-rented --headless

# Postgres backup (VM / Linux; set PGPASSWORD and paths; run as root or docker group).
# 15 7 * * * PGPASSWORD=your_db_pass BACKUP_ROOT=/opt/backups/mls /opt/mls-automation/scripts/backup_postgres.sh >> /opt/mls-automation/logs/backup.log 2>&1

# Copy this file to `.env` in the same folder as `README.md` (the copy is gitignored).
# The app loads `.env` automatically—you do not need to “export” variables in the terminal.

# --- Database ---
# Optional on your Mac / same-machine Docker: if you omit DATABASE_URL, the app uses the
# default URL that matches `docker-compose.yml` (local Postgres only).
# On a real production server, set DATABASE_URL to your real Postgres URL and use MLS_PRODUCTION=1.
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@localhost:5432/mls_analytics

# Set to 1 only on servers where Postgres is NOT the default local Docker URL above.
# MLS_PRODUCTION=1

# --- Ops dashboard (optional) ---
# When both are set, /ops* routes require HTTP Basic auth.
# OPS_BASIC_AUTH_USER=
# OPS_BASIC_AUTH_PASSWORD=
# Set to 1 on Linux to show load average on /ops/overview (non-secret).
# OPS_EXTENDED_METRICS=1
# Override path to the backup heartbeat file (default: /opt/backups/mls/.last_backup_heartbeat).
# OPS_BACKUP_HEARTBEAT_PATH=

# --- MLS scraping ---
# MLS_USERNAME=
# MLS_PASSWORD=
